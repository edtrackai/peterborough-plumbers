  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://[DOMAIN]/#business",
      "name": "Peterborough Plumbers",
      "url": "https://[DOMAIN]",
      "telephone": "[REAL-NUMBER]",
      "email": "[EMAIL]",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "[STREET]",
        "addressLocality": "Peterborough",
        "addressRegion": "Cambridgeshire",
        "postalCode": "[POSTCODE]",
        "addressCountry": "GB"
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Peterborough"
        },
        {
          "@type": "City",
          "name": "Bretton"
        },
        {
          "@type": "City",
          "name": "Hampton"
        },
        {
          "@type": "City",
          "name": "Millfield"
        },
        {
          "@type": "City",
          "name": "Werrington"
        },
        {
          "@type": "City",
          "name": "Woodston"
        },
        {
          "@type": "City",
          "name": "Stanground"
        },
        {
          "@type": "City",
          "name": "Paston"
        },
        {
          "@type": "City",
          "name": "Gunthorpe"
