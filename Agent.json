    {
      "parameters": {
        "promptType": "define",
        "text": "=Classify this WhatsApp message and return strict JSON only.\\n\\nCustomer name: {{ $('Normalize Input').item.json.senderName }}\\nWhatsApp number: {{ $('Normalize Input').item.json.from }}\\nMessage: {{ $('Normalize Input').item.json.text }}\\n\\nReturn keys:\\nintent, route, risk, needsHuman, confidence, serviceType, issueSummary\\n\\nroute must be one of: business, general, emergency, human\\nrisk must be one of: low, medium, high",
        "options": {
          "systemMessage": "You are a strict intent router for a UK plumbing WhatsApp assistant. Output JSON only. Use route=general when the question is a general plumbing/heating question not dependent on company policy. Use route=business for service area, booking, quote, company policy, pricing process, or company-specific questions. Use route=emergency for urgent leaks, flooding, no heating/hot water in urgent context, boiler breakdown with urgency, sewage overflow, water through ceiling, cannot isolate water, vulnerable occupants, or gas smell. Use route=human when user explicitly asks for a human or is angry/distressed."
        }
      },
      "id": "d9db3948-1e47-41bf-8f2d-feda2da1a509",
      "name": "Intent Router",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        1344,
        16
