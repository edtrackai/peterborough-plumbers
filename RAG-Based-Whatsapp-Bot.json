    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || '';\n\n// Extract [[LEAD:{...}]] marker if present\nconst match = raw.match(/\\[\\[LEAD:(\\{.*?\\})\\]\\]/s);\n\nlet leadData = null;\nif (match) {\n  try {\n    leadData = JSON.parse(match[1]);\n  } catch(e) {\n    leadData = null;\n  }\n}\n\n// Strip the marker from the message sent to customer\nconst cleanMessage = raw.replace(/\\n?\\[\\[LEAD:\\{.*?\\}\\]\\]/s, '').trim();\n\nreturn [{\n  json: {\n    agentReply: cleanMessage,\n    leadData: leadData,\n    hasLead: leadData !== null,\n    waId: $('Normalize Input').first().json.from\n  }\n}];"
      },
