// Prisma schema — Peterborough Plumbers
// Run: npx prisma db push
// Seed: npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ServiceZone ───────────────────────────────────────────────────────────────

model ServiceZone {
  id               String   @id @default(cuid())
  prefix           String   @unique // "PE1", "PE2", etc.
  zoneName         String           // "City Centre", "Werrington"
  isActive         Boolean  @default(true)
  travelBufferMins Int      @default(15)
  createdAt        DateTime @default(now())

  @@index([prefix, isActive])
  @@map("pb_service_zones")
}

// ── TimeSlot ──────────────────────────────────────────────────────────────────

model TimeSlot {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date // 2026-02-24
  startTime   String              // "09:00"
  endTime     String              // "11:00"
  capacity    Int       @default(2)
  bookedCount Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  bookings    Booking[]

  @@unique([date, startTime])
  @@index([date, isActive])
  @@index([bookedCount])
  @@map("pb_time_slots")
}

// ── Plumber ───────────────────────────────────────────────────────────────────

model Plumber {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  isActive     Boolean   @default(true)
  isOnDuty     Boolean   @default(false)
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Approval flow
  // pending_verification | needs_more_info | approved | rejected | suspended
  approvalStatus    String  @default("pending_verification")
  plumberId         String? @unique  // PLM-000001 — generated only on admin approval
  adminNote         String? @db.Text // visible to plumber (rejection/info reason)

  // Service permissions / badges
  verifiedGeneral   Boolean @default(false) // approved for all general plumbing jobs
  boilerGasApproved Boolean @default(false) // approved for boiler & gas work

  bookings  Booking[]        @relation("AssignedPlumber")
  offers    BookingOffer[]
  events    BookingEvent[]
  locations BookingLocation[]
  docs      PlumberDoc[]

  @@map("pb_plumbers")
}

// ── PlumberDoc ────────────────────────────────────────────────────────────────
// docType: photo_id | selfie | proof_of_address | public_liability_insurance
//          | dbs_certificate | gas_safe_certificate

model PlumberDoc {
  id         String   @id @default(cuid())
  plumberId  String
  plumber    Plumber  @relation(fields: [plumberId], references: [id], onDelete: Cascade)
  docType    String
  url        String
  publicId   String?
  uploadedAt DateTime @default(now())

  @@index([plumberId])
  @@map("pb_plumber_docs")
}

// ── Booking ───────────────────────────────────────────────────────────────────

model Booking {
  id                String    @id @default(cuid())
  bookingRef        String    @unique // "PB-260224-0042"
  // status: reserved | pending_assignment | accepted | en_route | arrived | in_progress | completed | cancelled | expired | new | confirmed
  status            String    @default("reserved")
  postcode          String
  zonePrefix        String
  slotId            String
  slot              TimeSlot  @relation(fields: [slotId], references: [id])
  serviceType       String?
  description       String?
  customerName      String?
  phone             String?
  email             String?
  address           String?
  accessNotes       String?
  assignedPlumberId String?
  assignedPlumber   Plumber?  @relation("AssignedPlumber", fields: [assignedPlumberId], references: [id])
  estimatedArrival  DateTime? // ETA set when plumber accepts or goes en_route
  reservedAt        DateTime  @default(now())
  expiresAt         DateTime?
  confirmedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  images        BookingImage[]
  offers        BookingOffer[]
  events        BookingEvent[]
  locations     BookingLocation[]
  rating        BookingRating?
  notifications BookingNotification[]

  @@index([bookingRef])
  @@index([status])
  @@index([status, expiresAt]) // cleanupExpired: where status="reserved" AND expiresAt < now
  @@index([createdAt(sort: Desc)])
  @@index([zonePrefix])
  @@index([assignedPlumberId])
  @@map("pb_bookings")
}

// ── BookingImage ──────────────────────────────────────────────────────────────

model BookingImage {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("pb_booking_images")
}

// ── BookingOffer ──────────────────────────────────────────────────────────────

model BookingOffer {
  id           String    @id @default(cuid())
  bookingId    String
  booking      Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  plumberId    String
  plumber      Plumber   @relation(fields: [plumberId], references: [id])
  // status: offered | accepted | rejected | expired
  status       String    @default("offered")
  rejectReason String?
  rejectNote   String?
  offeredAt    DateTime  @default(now())
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([bookingId])
  @@index([plumberId])
  @@index([status])
  @@map("pb_booking_offers")
}

// ── BookingEvent ──────────────────────────────────────────────────────────────

model BookingEvent {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  plumberId String?
  plumber   Plumber? @relation(fields: [plumberId], references: [id])
  // eventType: offered | accepted | rejected | en_route | arrived | in_progress | completed | note | cancelled | pending_assignment
  eventType String
  notes     String?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("pb_booking_events")
}

// ── BookingLocation ───────────────────────────────────────────────────────────

model BookingLocation {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  plumberId String
  plumber   Plumber  @relation(fields: [plumberId], references: [id])
  lat       Float
  lng       Float
  accuracy  Float?
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("pb_booking_locations")
}

// ── BookingNotification ───────────────────────────────────────────────────────

model BookingNotification {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  // type: accepted | en_route | arrived | completed | cancelled | rescheduled
  type      String
  // channel: email | sms | whatsapp
  channel   String
  recipient String   // email address or phone number notified
  message   String   @db.Text
  success   Boolean  @default(true)
  errorMsg  String?
  sentAt    DateTime @default(now())

  @@index([bookingId])
  @@index([type])
  @@map("pb_booking_notifications")
}

// ── BookingRating ─────────────────────────────────────────────────────────────

model BookingRating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("pb_booking_ratings")
}

// ── Lead ──────────────────────────────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  postcode    String
  serviceType String?
  // status: new | contacted | converted | closed
  status      String   @default("new")
  source      String   @default("contact_form")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("pb_leads")
}

// ── Service ───────────────────────────────────────────────────────────────────

model Service {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String
  heroHeading      String
  heroSubheading   String
  content          String   @db.Text
  faqs             Json
  seoTitle         String
  seoDescription   String
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  image            String?
  heroImage        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([featured])
  @@map("pb_services")
}

// ── BlogPost ──────────────────────────────────────────────────────────────────

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  category       String
  excerpt        String    @db.Text
  content        String    @db.Text
  seoTitle       String
  seoDescription String
  image          String?
  status         String    @default("Draft")
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
  @@map("pb_blog_posts")
}

// ── Guide ─────────────────────────────────────────────────────────────────────

model Guide {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  excerpt        String   @db.Text
  category       String
  readTime       Int
  publishedAt    DateTime
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@map("pb_guides")
}

// ── Area ──────────────────────────────────────────────────────────────────────

model Area {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  intro          String   @db.Text
  content        String   @db.Text @default("")
  faqs           Json     @default("[]")
  landmarks      Json
  postcodes      Json
  seoTitle       String
  seoDescription String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@map("pb_areas")
}

// ── Review ────────────────────────────────────────────────────────────────────

model Review {
  id           String   @id @default(cuid())
  customerName String
  areaName     String
  rating       Int
  body         String   @db.Text
  source       String   @default("Google")
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([featured])
  @@index([areaName]) // area pages: where areaName = area.name (insensitive)
  @@map("pb_reviews")
}

// ── Pricing ───────────────────────────────────────────────────────────────────

model Pricing {
  id           String   @id @default(cuid())
  serviceSlug  String   @unique
  serviceName  String
  price        String   // e.g. "£79", "From £99", "POA"
  priceLabel   String   @default("From") // e.g. "From", "Fixed", "Starting at"
  priceNote    String?  // optional short note shown alongside the price
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([serviceSlug])
  @@map("pb_pricing")
}

// ── SiteSettings ──────────────────────────────────────────────────────────────

model SiteSettings {
  id                     String @id @default("singleton")
  companyName            String
  phone                  String
  phoneHref              String
  whatsappNumber         String
  email                  String
  address                String
  gasSafeNumber          String
  googleRating           String
  reviewCount            String
  yearsExperience        String
  engineersCount         String
  primaryCtaLabel        String
  primaryCtaHref         String
  secondaryCtaLabel      String
  whatsappPrefillMessage String
  siteUrl                String
  seoTitle               String
  seoDescription         String

  @@map("pb_site_settings")
}

// ── ChatSession ───────────────────────────────────────────────────────────────

model ChatSession {
  id         String        @id @default(cuid())
  createdAt  DateTime      @default(now())
  lastSeenAt DateTime      @default(now())
  sourcePage String?

  messages   ChatMessage[]
  leads      ChatLead[]

  @@index([createdAt(sort: Desc)])
  @@map("pb_chat_sessions")
}

// ── ChatMessage ───────────────────────────────────────────────────────────────

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // 'user' | 'assistant'
  content   String      @db.Text
  category  String?
  isBlocked Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt(sort: Desc)])
  @@map("pb_chat_messages")
}

// ── ChatLead ──────────────────────────────────────────────────────────────────

model ChatLead {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name      String?
  phone     String?
  postcode  String?
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@map("pb_chat_leads")
}

// ── WaChat (WhatsApp conversation per phone number) ──────────────────────────

model WaChat {
  id            String      @id @default(cuid())
  waId          String      @unique // WhatsApp phone number (e.g. "447700900000")
  customerName  String?
  customerPhone String?
  postcode      String?
  serviceType   String?
  botActive     Boolean     @default(true)
  isEmergency   Boolean     @default(false)
  leadCaptured  Boolean     @default(false)
  lastMessageAt DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  messages      WaMessage[]

  @@index([lastMessageAt(sort: Desc)])
  @@index([botActive])
  @@map("pb_wa_chats")
}

// ── WaMessage (individual WhatsApp messages) ─────────────────────────────────

model WaMessage {
  id          String   @id @default(cuid())
  chatId      String
  chat        WaChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        String   // "user" | "assistant"
  content     String   @db.Text
  waMessageId String?  @unique // Meta message ID for dedup
  category    String?
  createdAt   DateTime @default(now())

  @@index([chatId])
  @@index([createdAt(sort: Desc)])
  @@map("pb_wa_messages")
}

// ── Call (voice call session) ─────────────────────────────────────────────────
// Prepared for future Meta Calling API + OpenAI Realtime integration.
// leadId is nullable — linked after lead is captured during or after the call.

model Call {
  id              String    @id @default(cuid())
  // direction: inbound | outbound
  direction       String    @default("inbound")
  // status: initiated | active | on_hold | ended | failed | missed
  status          String    @default("initiated")
  // source: whatsapp_call | phone | test
  source          String    @default("whatsapp_call")
  // outcome: emergency_escalated | human_handoff | qualified_lead_captured | general_advice_given | follow_up_requested | no_action
  outcome         String?
  waId            String?   // WhatsApp phone number if applicable
  phone           String?   // raw caller number
  leadId          String?   // linked Lead if captured
  durationSeconds Int?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transcripts     CallTranscript[]
  summary         CallSummary?
  events          CallEvent[]

  @@index([status])
  @@index([waId])
  @@index([startedAt(sort: Desc)])
  @@map("pb_calls")
}

// ── CallTranscript (per-turn transcript during a call) ────────────────────────

model CallTranscript {
  id        String   @id @default(cuid())
  callId    String
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  // speaker: user | agent | system
  speaker   String
  text      String   @db.Text
  // intent logged per turn when classified
  intent    String?
  turnIndex Int      @default(0)
  spokenAt  DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([callId])
  @@index([callId, turnIndex])
  @@map("pb_call_transcripts")
}

// ── CallSummary (post-call structured summary) ────────────────────────────────

model CallSummary {
  id            String   @id @default(cuid())
  callId        String   @unique
  call          Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  summary       String   @db.Text
  // urgency: low | medium | high
  urgency       String?
  serviceType   String?
  issueSummary  String?
  preferredTime String?
  needsHuman      Boolean  @default(false)
  endState        String?  // matches outcome values from Call
  transcriptText  String?  @db.Text
  createdAt       DateTime @default(now())

  @@map("pb_call_summaries")
}

// ── CallEvent (lifecycle events for a call) ───────────────────────────────────

model CallEvent {
  id        String   @id @default(cuid())
  callId    String
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  // eventType: started | agent_greeted | intent_classified | lead_updated | escalated | ended | error
  eventType String
  notes     String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([callId])
  @@map("pb_call_events")
}
