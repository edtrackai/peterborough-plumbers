generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServiceZone {
  id               String   @id @default(cuid())
  prefix           String   @unique
  zoneName         String
  isActive         Boolean  @default(true)
  travelBufferMins Int      @default(15)
  createdAt        DateTime @default(now())

  @@index([prefix, isActive])
  @@map("pb_service_zones")
}

model TimeSlot {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  startTime   String
  endTime     String
  capacity    Int       @default(2)
  bookedCount Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  bookings    Booking[]

  @@unique([date, startTime])
  @@index([date, isActive])
  @@index([bookedCount])
  @@map("pb_time_slots")
}

model Plumber {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  phone             String?
  passwordHash      String
  isActive          Boolean           @default(true)
  isOnDuty          Boolean           @default(false)
  lastSeenAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  adminNote         String?
  approvalStatus    String            @default("pending_verification")
  boilerGasApproved Boolean           @default(false)
  gasSafeNumber     String?
  plumberId         String?           @unique
  verifiedGeneral   Boolean           @default(false)
  gasSafeCertExpiry DateTime?
  plumberType       String            @default("general")
  events            BookingEvent[]
  locations         BookingLocation[]
  offers            BookingOffer[]
  bookings          Booking[]         @relation("AssignedPlumber")
  leadDispatches    LeadDispatch[]
  assignedLeads     Lead[]            @relation("AssignedLeads")
  docs              PlumberDoc[]

  @@map("pb_plumbers")
}

model PlumberDoc {
  id         String   @id @default(cuid())
  plumberId  String
  docType    String
  url        String
  publicId   String?
  uploadedAt DateTime @default(now())
  plumber    Plumber  @relation(fields: [plumberId], references: [id], onDelete: Cascade)

  @@index([plumberId])
  @@map("pb_plumber_docs")
}

model Booking {
  id                String                @id @default(cuid())
  bookingRef        String                @unique
  status            String                @default("reserved")
  postcode          String
  zonePrefix        String
  slotId            String
  serviceType       String?
  description       String?
  customerName      String?
  phone             String?
  email             String?
  address           String?
  accessNotes       String?
  reservedAt        DateTime              @default(now())
  expiresAt         DateTime?
  confirmedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  assignedPlumberId String?
  completedAt       DateTime?
  estimatedArrival  DateTime?
  events            BookingEvent[]
  images            BookingImage[]
  locations         BookingLocation[]
  notifications     BookingNotification[]
  offers            BookingOffer[]
  rating            BookingRating?
  assignedPlumber   Plumber?              @relation("AssignedPlumber", fields: [assignedPlumberId], references: [id])
  slot              TimeSlot              @relation(fields: [slotId], references: [id])

  @@index([bookingRef])
  @@index([status])
  @@index([status, expiresAt])
  @@index([createdAt(sort: Desc)])
  @@index([zonePrefix])
  @@index([assignedPlumberId])
  @@map("pb_bookings")
}

model BookingImage {
  id        String   @id @default(cuid())
  bookingId String
  url       String
  publicId  String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("pb_booking_images")
}

model BookingOffer {
  id           String    @id @default(cuid())
  bookingId    String
  plumberId    String
  status       String    @default("offered")
  rejectReason String?
  rejectNote   String?
  offeredAt    DateTime  @default(now())
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())
  booking      Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  plumber      Plumber   @relation(fields: [plumberId], references: [id])

  @@index([bookingId])
  @@index([plumberId])
  @@index([status])
  @@map("pb_booking_offers")
}

model BookingEvent {
  id        String   @id @default(cuid())
  bookingId String
  plumberId String?
  eventType String
  notes     String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  plumber   Plumber? @relation(fields: [plumberId], references: [id])

  @@index([bookingId])
  @@map("pb_booking_events")
}

model BookingLocation {
  id        String   @id @default(cuid())
  bookingId String
  plumberId String
  lat       Float
  lng       Float
  accuracy  Float?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  plumber   Plumber  @relation(fields: [plumberId], references: [id])

  @@index([bookingId])
  @@map("pb_booking_locations")
}

model BookingNotification {
  id        String   @id @default(cuid())
  bookingId String
  type      String
  channel   String
  recipient String
  message   String
  success   Boolean  @default(true)
  errorMsg  String?
  sentAt    DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([type])
  @@map("pb_booking_notifications")
}

model BookingRating {
  id        String   @id @default(cuid())
  bookingId String   @unique
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("pb_booking_ratings")
}

model Lead {
  id                String         @id @default(cuid())
  name              String
  phone             String
  email             String?
  postcode          String
  serviceType       String?
  status            String         @default("new")
  source            String         @default("contact_form")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  notes             String?
  preferredTime     String?
  assignedPlumberId String?
  dispatches        LeadDispatch[]
  assignedPlumber   Plumber?       @relation("AssignedLeads", fields: [assignedPlumberId], references: [id])

  @@index([status])
  @@index([assignedPlumberId])
  @@index([createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)], map: "pb_leads_createdat_idx")
  @@map("pb_leads")
}

model LeadDispatch {
  id              String    @id @default(cuid())
  leadId          String
  plumberId       String
  status          String    @default("offered")
  dispatchMessage String?   @db.Text
  plumberReply    String?   @db.Text
  offeredAt       DateTime  @default(now())
  respondedAt     DateTime?
  createdAt       DateTime  @default(now())
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  plumber         Plumber   @relation(fields: [plumberId], references: [id])

  @@unique([leadId, plumberId])
  @@index([leadId])
  @@index([plumberId])
  @@index([status])
  @@map("pb_lead_dispatches")
}

model Service {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String
  heroHeading      String
  heroSubheading   String
  content          String
  faqs             Json
  seoTitle         String
  seoDescription   String
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  image            String?
  heroImage        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([featured])
  @@map("pb_services")
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  category       String
  excerpt        String
  content        String
  seoTitle       String
  seoDescription String
  status         String    @default("Draft")
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  image          String?

  @@index([slug])
  @@index([status, publishedAt])
  @@map("pb_blog_posts")
}

model Guide {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  excerpt     String
  category    String
  readTime    Int
  publishedAt DateTime
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@map("pb_guides")
}

model Area {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  intro          String
  landmarks      Json
  postcodes      Json
  seoTitle       String
  seoDescription String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  content        String   @default("")
  faqs           Json     @default("[]")

  @@index([slug])
  @@map("pb_areas")
}

model Review {
  id           String   @id @default(cuid())
  customerName String
  areaName     String
  rating       Int
  body         String
  source       String   @default("Google")
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([featured])
  @@index([areaName])
  @@map("pb_reviews")
}

model Pricing {
  id          String   @id @default(cuid())
  serviceSlug String   @unique
  serviceName String
  price       String
  priceLabel  String   @default("From")
  priceNote   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceSlug])
  @@map("pb_pricing")
}

model SiteSettings {
  id                     String @id @default("singleton")
  companyName            String
  phone                  String
  phoneHref              String
  whatsappNumber         String
  email                  String
  address                String
  gasSafeNumber          String
  googleRating           String
  reviewCount            String
  yearsExperience        String
  engineersCount         String
  primaryCtaLabel        String
  primaryCtaHref         String
  secondaryCtaLabel      String
  whatsappPrefillMessage String
  siteUrl                String
  seoTitle               String
  seoDescription         String

  @@map("pb_site_settings")
}

model ChatSession {
  id         String        @id @default(cuid())
  createdAt  DateTime      @default(now())
  lastSeenAt DateTime      @default(now())
  sourcePage String?
  leads      ChatLead[]
  messages   ChatMessage[]

  @@index([createdAt(sort: Desc)])
  @@map("pb_chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  category  String?
  isBlocked Boolean     @default(false)
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt(sort: Desc)])
  @@map("pb_chat_messages")
}

model ChatLead {
  id        String      @id @default(cuid())
  sessionId String
  name      String?
  phone     String?
  postcode  String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("pb_chat_leads")
}

model WaChat {
  id            String      @id @default(cuid())
  waId          String      @unique
  customerName  String?
  customerPhone String?
  postcode      String?
  serviceType   String?
  botActive     Boolean     @default(true)
  isEmergency   Boolean     @default(false)
  lastMessageAt DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  leadCaptured  Boolean     @default(false)
  messages      WaMessage[]

  @@index([lastMessageAt(sort: Desc)])
  @@index([botActive])
  @@map("pb_wa_chats")
}

model WaMessage {
  id          String   @id @default(cuid())
  chatId      String
  role        String
  content     String
  waMessageId String?  @unique
  category    String?
  createdAt   DateTime @default(now())
  chat        WaChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt(sort: Desc)])
  @@map("pb_wa_messages")
}

model Call {
  id              String           @id @default(cuid())
  direction       String           @default("inbound")
  status          String           @default("initiated")
  source          String           @default("whatsapp_call")
  outcome         String?
  waId            String?
  phone           String?
  leadId          String?
  durationSeconds Int?
  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  events          CallEvent[]
  summary         CallSummary?
  transcripts     CallTranscript[]

  @@index([status])
  @@index([waId])
  @@index([startedAt(sort: Desc)])
  @@map("pb_calls")
}

model CallTranscript {
  id        String   @id @default(cuid())
  callId    String
  speaker   String
  text      String
  intent    String?
  turnIndex Int      @default(0)
  spokenAt  DateTime @default(now())
  createdAt DateTime @default(now())
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@index([callId, turnIndex])
  @@map("pb_call_transcripts")
}

model CallSummary {
  id             String   @id @default(cuid())
  callId         String   @unique
  summary        String
  urgency        String?
  serviceType    String?
  issueSummary   String?
  preferredTime  String?
  needsHuman     Boolean  @default(false)
  endState       String?
  createdAt      DateTime @default(now())
  transcriptText String?
  call           Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@map("pb_call_summaries")
}

model KnowledgeChunk {
  id        String   @id @default(cuid())
  section   String
  title     String
  content   String
  embedding String?
  createdAt DateTime @default(now())

  @@index([section])
  @@map("pb_knowledge_chunks")
}

model CallEvent {
  id        String   @id @default(cuid())
  callId    String
  eventType String
  notes     String?
  meta      Json?
  createdAt DateTime @default(now())
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("pb_call_events")
}

view VBookingFull {
  id               String    @unique
  bookingRef       String
  status           String
  postcode         String
  zonePrefix       String
  serviceType      String?
  description      String?
  customerName     String?
  phone            String?
  email            String?
  address          String?
  accessNotes      String?
  reservedAt       DateTime
  confirmedAt      DateTime?
  completedAt      DateTime?
  estimatedArrival DateTime?
  expiresAt        DateTime?
  createdAt        DateTime
  updatedAt        DateTime
  slotDate         DateTime? @db.Date
  slotStart        String?
  slotEnd          String?
  plumberId        String?
  plumberName      String?
  plumberEmail     String?
  plumberPhone     String?
  plumberOnDuty    Boolean?
  ratingStars      Int?
  ratingComment    String?
  offerCount       BigInt?
  imageCount       BigInt?

  @@map("v_booking_full")
}

view VCallFull {
  id                 String    @unique
  direction          String
  status             String
  source             String
  outcome            String?
  waId               String?
  phone              String?
  leadId             String?
  durationSeconds    Int?
  startedAt          DateTime
  endedAt            DateTime?
  createdAt          DateTime
  callSummary        String?
  urgency            String?
  summaryServiceType String?
  issueSummary       String?
  preferredTime      String?
  needsHuman         Boolean?
  endState           String?
  transcriptText     String?
  transcriptTurns    BigInt?
  eventCount         BigInt?

  @@map("v_call_full")
}

view VWhatsappOverview {
  id              String   @unique
  waId            String
  customerName    String?
  customerPhone   String?
  postcode        String?
  serviceType     String?
  botActive       Boolean
  isEmergency     Boolean
  leadCaptured    Boolean
  lastMessageAt   DateTime
  createdAt       DateTime
  totalMessages   BigInt?
  userMessages    BigInt?
  botMessages     BigInt?
  lastMessage     String?
  lastMessageRole String?

  @@map("v_whatsapp_overview")
}

view VPlumberStats {
  id                String    @unique
  name              String
  email             String
  phone             String?
  isActive          Boolean
  isOnDuty          Boolean
  lastSeenAt        DateTime?
  createdAt         DateTime
  totalBookings     BigInt?
  completedBookings BigInt?
  activeBookings    BigInt?
  cancelledBookings BigInt?
  avgRating         Decimal?  @db.Decimal
  totalRatings      BigInt?
  pendingOffers     BigInt?
  rejectedOffers    BigInt?

  @@map("v_plumber_stats")
}

view VLeadPipeline {
  id          String   @unique
  name        String
  phone       String
  email       String?
  postcode    String
  serviceType String?
  status      String
  source      String
  createdAt   DateTime
  updatedAt   DateTime
  ageHours    Decimal? @db.Decimal

  @@map("v_lead_pipeline")
}
